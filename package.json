{
  "name": "coolify-11d",
  "version": "0.1.0",
  "description": "Unified CLI, MCP server, and Claude.ai connector for self-hosted Coolify. Enforces the -11d naming convention and optimizes AI context windows.",
  "type": "module",
  "license": "MIT",
  "author": "v3ct0r (Marcus)",
  "homepage": "https://github.com/v3ct0r/coolify-11d",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/v3ct0r/coolify-11d.git"
  },
  "keywords": [
    "coolify",
    "mcp",
    "model-context-protocol",
    "cli",
    "claude",
    "devops",
    "self-hosted"
  ],
  "bin": {
    "coolify-11d": "./dist/cli.js",
    "coolify-11d-mcp": "./dist/mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/connector/server.ts",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/server.ts",
    "build": "tsup",
    "start": "node dist/connector/server.js",
    "start:cli": "node dist/cli.js",
    "start:mcp": "node dist/mcp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "COOLIFY_INTEGRATION=1 vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "coverage": "vitest run --coverage",
    "lint": "biome lint src tests",
    "format": "biome format --write src tests",
    "check": "biome check src tests && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "conf": "^13.1.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "msw": "^2.7.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  }
}
