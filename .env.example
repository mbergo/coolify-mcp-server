# ---- Coolify target ----
COOLIFY_BASE_URL=https://xyz.v3ct0r.one
COOLIFY_TOKEN=

# ---- Connector (SSE server) ----
PORT=3111
# Bearer token required on /mcp/* and write /api/* routes.
# Unset = bind to 127.0.0.1 only with warning.
CONNECTOR_AUTH_TOKEN=

# ---- Behavior ----
# Collision policy when name already ends in -11d: error | increment | prompt
COOLIFY_NAMING_COLLISION=increment
# Naming suffix (default: 11d)
COOLIFY_NAMING_SUFFIX=11d

# ---- Render deploy (CI / local render-deploy target) ----
RENDER_API_KEY=
RENDER_SERVICE_ID=

# ---- Test toggles ----
# Set to 1 to enable live integration tests against COOLIFY_BASE_URL
COOLIFY_INTEGRATION=0
